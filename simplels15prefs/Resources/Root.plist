<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>items</key>
	<array>
		<dict>
			<key>cell</key> <string>PSButtonCell</string>
			<key>label</key> <string>⚡ ÁP DỤNG &amp; RESPRING</string>
			<key>action</key> <string>respring</string>
		</dict>
		<dict>
			<key>cell</key> <string>PSSwitchCell</string>
			<key>defaults</key> <string>com.tuan.simplels15</string>
			<key>key</key> <string>enabled</string>
			<key>label</key> <string>Bật SimpleLS15</string>
			<key>default</key> <true/>
			<key>PostNotification</key> <string>com.tuan.simplels15/ReloadPrefs</string>
		</dict>
		<dict>
			<key>cell</key> <string>PSGroupCell</string>
			<key>label</key> <string>Căn lề Đồng hồ</string>
		</dict>
		<dict>
			<key>cell</key> <string>PSSegmentCell</string>
			<key>defaults</key> <string>com.tuan.simplels15</string>
			<key>key</key> <string>alignment</string>
			<key>default</key> <integer>1</integer>
			<key>validTitles</key>
			<array> <string>Trái</string> <string>Giữa</string> <string>Phải</string> </array>
			<key>validValues</key>
			<array> <integer>0</integer> <integer>1</integer> <integer>2</integer> </array>
			<key>PostNotification</key> <string>com.tuan.simplels15/ReloadPrefs</string>
		</dict>
		<dict>
			<key>cell</key> <string>PSGroupCell</string>
			<key>label</key> <string>Di chuyển Lên / Xuống (Trục Y)</string>
		</dict>
		<dict>
			<key>cell</key> <string>PSSliderCell</string>
			<key>defaults</key> <string>com.tuan.simplels15</string>
			<key>key</key> <string>yOffset</string>
			<key>min</key> <real>-50.0</real>
			<key>max</key> <real>250.0</real>
			<key>default</key> <real>0.0</real>
			<key>showValue</key> <true/>
			<key>PostNotification</key> <string>com.tuan.simplels15/ReloadPrefs</string>
		</dict>
		<dict>
			<key>cell</key> <string>PSGroupCell</string>
			<key>label</key> <string>Tùy chỉnh Font chữ</string>
		</dict>
		<dict>
			<key>cell</key> <string>PSLinkListCell</string>
			<key>defaults</key> <string>com.tuan.simplels15</string>
			<key>key</key> <string>fontName</string>
			<key>label</key> <string>Tên Font:</string>
			<key>detail</key> <string>PSListItemsController</string>
			<key>validTitles</key>
			<array>
				<string>Hệ thống</string>
				<string>Lobster</string>
				<string>Arial</string>
			</array>
			<key>validValues</key>
			<array>
				<string>System</string>
				<string>Lobster</string> 
				<string>ArialMT</string>
			</array>
			<key>default</key> <string>System</string>
			<key>PostNotification</key> <string>com.tuan.simplels15/ReloadPrefs</string>
		</dict>
		<dict>
			<key>cell</key> <string>PSLinkListCell</string>
			<key>defaults</key> <string>com.tuan.simplels15</string>
			<key>key</key> <string>fontStyle</string>
			<key>label</key> <string>Định dạng:</string>
			<key>detail</key> <string>PSListItemsController</string>
			<key>validTitles</key>
			<array>
				<string>Bình thường (Normal)</string>
				<string>Nét Đậm (Bold)</string>
				<string>Thủy tinh 3D (Glass)</string>
			</array>
			<key>validValues</key>
			<array>
				<string>Normal</string>
				<string>Bold</string>
				<string>Glass</string>
			</array>
			<key>default</key> <string>Normal</string>
			<key>PostNotification</key> <string>com.tuan.simplels15/ReloadPrefs</string>
		</dict>
		<dict>
			<key>cell</key> <string>PSGroupCell</string>
			<key>footerText</key> <string>Created by: Anh Tuan</string>
			<key>footerAlignment</key> <integer>1</integer>
		</dict>
	</array>
	<key>title</key> <string>SimpleLS15</string>
</dict>
</plist>