<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>items</key>
	<array>
		<dict>
			<key>cell</key> <string>PSButtonCell</string>
			<key>label</key> <string>⚡ ÁP DỤNG &amp; RESPRING</string>
			<key>action</key> <string>respring</string>
		</dict>

		<dict>
			<key>cell</key> <string>PSGroupCell</string>
			<key>label</key> <string>VỊ TRÍ &amp; HIỂN THỊ</string>
		</dict>
		<dict>
			<key>cell</key> <string>PSSwitchCell</string>
			<key>defaults</key> <string>com.tuan.simplels15</string>
			<key>key</key> <string>enabled</string>
			<key>label</key> <string>Bật SimpleLS15</string>
			<key>default</key> <true/>
			<key>PostNotification</key> <string>com.tuan.simplels15/ReloadPrefs</string>
		</dict>
		<dict>
			<key>cell</key> <string>PSSliderCell</string>
			<key>defaults</key> <string>com.tuan.simplels15</string>
			<key>key</key> <string>yOffset</string>
			<key>min</key> <real>-100.0</real>
			<key>max</key> <real>300.0</real>
			<key>default</key> <real>0.0</real>
			<key>showValue</key> <true/>
			<key>PostNotification</key> <string>com.tuan.simplels15/ReloadPrefs</string>
		</dict>

		<dict>
			<key>cell</key> <string>PSGroupCell</string>
			<key>label</key> <string>KÍCH THƯỚC FONT</string>
		</dict>
		<dict>
			<key>cell</key> <string>PSSliderCell</string>
			<key>defaults</key> <string>com.tuan.simplels15</string>
			<key>key</key> <string>sizeClock</string>
			<key>min</key> <real>30.0</real>
			<key>max</key> <real>120.0</real>
			<key>default</key> <real>80.0</real>
			<key>showValue</key> <true/>
			<key>PostNotification</key> <string>com.tuan.simplels15/ReloadPrefs</string>
		</dict>
		<dict>
			<key>cell</key> <string>PSSliderCell</string>
			<key>defaults</key> <string>com.tuan.simplels15</string>
			<key>key</key> <string>sizeDate</string>
			<key>min</key> <real>10.0</real>
			<key>max</key> <real>40.0</real>
			<key>default</key> <real>20.0</real>
			<key>showValue</key> <true/>
			<key>PostNotification</key> <string>com.tuan.simplels15/ReloadPrefs</string>
		</dict>

		<dict>
			<key>cell</key> <string>PSGroupCell</string>
			<key>label</key> <string>KIỂU CHỮ &amp; ĐỊNH DẠNG</string>
		</dict>
		<dict>
			<key>cell</key> <string>PSLinkListCell</string>
			<key>defaults</key> <string>com.tuan.simplels15</string>
			<key>key</key> <string>fontName</string>
			<key>label</key> <string>Chọn Font:</string>
			<key>detail</key> <string>PSListItemsController</string>
			<key>validTitles</key>
			<array> <string>Hệ thống</string> <string>Lobster</string> <string>Arial</string> </array>
			<key>validValues</key>
			<array> <string>System</string> <string>Lobster</string> <string>ArialMT</string> </array>
			<key>default</key> <string>System</string>
		</dict>
		<dict>
			<key>cell</key> <string>PSLinkListCell</string>
			<key>defaults</key> <string>com.tuan.simplels15</string>
			<key>key</key> <string>fontStyle</string>
			<key>label</key> <string>Định dạng:</string>
			<key>detail</key> <string>PSListItemsController</string>
			<key>validTitles</key>
			<array> <string>Bình thường</string> <string>Đậm</string> <string>Nghiêng</string> <string>Glass</string> </array>
			<key>validValues</key>
			<array> <string>Normal</string> <string>Bold</string> <string>Italic</string> <string>Glass</string> </array>
			<key>default</key> <string>Normal</string>
		</dict>

		<dict>
			<key>cell</key> <string>PSGroupCell</string>
			<key>label</key> <string>ẨN THÀNH PHẦN</string>
		</dict>
		<dict>
			<key>cell</key> <string>PSSwitchCell</string>
			<key>defaults</key> <string>com.tuan.simplels15</string>
			<key>key</key> <string>hideWeather</string>
			<key>label</key> <string>Ẩn Thời tiết</string>
			<key>default</key> <false/>
		</dict>
		<dict>
			<key>cell</key> <string>PSSwitchCell</string>
			<key>defaults</key> <string>com.tuan.simplels15</string>
			<key>key</key> <string>hideLunar</string>
			<key>label</key> <string>Ẩn Lịch âm</string>
			<key>default</key> <false/>
		</dict>

		<dict>
			<key>cell</key> <string>PSGroupCell</string>
			<key>footerText</key> <string>Created by: Anh Tuan</string>
			<key>footerAlignment</key> <integer>1</integer>
		</dict>
	</array>
	<key>title</key> <string>SimpleLS15</string>
</dict>
</plist>
